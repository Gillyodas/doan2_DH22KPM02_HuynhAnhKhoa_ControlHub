    Rerank --> Planner
    Planner --> PlanOk
    PlanOk -- Không --> ErrPlan
    ErrPlan --> End1
    PlanOk -- Có --> Executor
    Executor --> ExecStep
    ExecStep --> Reasoning
    Reasoning --> Verifier
